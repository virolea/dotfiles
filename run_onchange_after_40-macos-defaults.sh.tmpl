#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
echo "==> Applying macOS preferences..."

# --- Trackpad: two-finger tap = secondary (right) click ---
defaults write com.apple.AppleMultitouchTrackpad TrackpadRightClick -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadRightClick -bool true
defaults -currentHost write NSGlobalDomain com.apple.trackpad.enableSecondaryClick -bool true

# --- Caps Lock -> Escape ---
# Apply immediately for this session...
hidutil property --set \
  '{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x700000029}]}' >/dev/null
# ...and (re)load the LaunchAgent so it persists across reboots.
PLIST="$HOME/Library/LaunchAgents/com.local.caps-to-esc.plist"
if [ -f "$PLIST" ]; then
  launchctl bootout "gui/$(id -u)/com.local.caps-to-esc" 2>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null || \
    launchctl load "$PLIST" 2>/dev/null || true
fi

# Apply the trackpad changes without a full logout.
killall Dock 2>/dev/null || true

echo "    Done. Log out/in once if the trackpad change doesn't take effect immediately."
{{ end -}}
